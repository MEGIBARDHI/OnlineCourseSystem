@model Enrollment
@{
    ViewData["Title"] = "Certifikata";
    Layout = null;
}
<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Certifikata - @Model.Course?.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Syne:wght@600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #f5f0e8; display: flex; align-items: center; justify-content: center;
               min-height: 100vh; font-family: 'Inter', sans-serif; }
        .cert-wrap { background: white; width: 900px; min-height: 600px; position: relative;
                     border: 3px solid #b8960c; padding: 60px 80px; text-align: center;
                     box-shadow: 0 20px 60px rgba(0,0,0,.15); }
        .cert-border { position: absolute; inset: 10px; border: 1px solid #d4af37; pointer-events: none; }
        .cert-corner { position: absolute; width: 50px; height: 50px; border-color: #b8960c;
                       border-style: solid; }
        .cert-corner.tl { top: 20px; left: 20px; border-width: 3px 0 0 3px; }
        .cert-corner.tr { top: 20px; right: 20px; border-width: 3px 3px 0 0; }
        .cert-corner.bl { bottom: 20px; left: 20px; border-width: 0 0 3px 3px; }
        .cert-corner.br { bottom: 20px; right: 20px; border-width: 0 3px 3px 0; }
        .cert-logo { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 700;
                     color: #b8960c; letter-spacing: 3px; margin-bottom: 10px; }
        .cert-subtitle { font-size: .75rem; letter-spacing: 4px; text-transform: uppercase;
                         color: #888; margin-bottom: 30px; }
        .cert-divider { width: 100px; height: 2px; background: linear-gradient(90deg, transparent, #b8960c, transparent);
                        margin: 0 auto 30px; }
        .cert-title { font-family: 'Playfair Display', serif; font-style: italic;
                      font-size: 1.1rem; color: #555; margin-bottom: 8px; }
        .cert-name { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 700;
                     color: #1a1a1a; margin-bottom: 20px; }
        .cert-body { font-size: 1rem; color: #555; line-height: 1.7; margin-bottom: 10px; }
        .cert-course { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700;
                       color: #1a1a1a; margin: 15px 0; }
        .cert-date { color: #888; font-size: .9rem; margin: 20px 0 40px; }
        .cert-signatures { display: flex; justify-content: space-around; margin-top: 40px; }
        .cert-sig { text-align: center; }
        .cert-sig-line { width: 150px; height: 1px; background: #333; margin: 0 auto 5px; }
        .cert-sig-name { font-size: .85rem; font-weight: 600; }
        .cert-sig-role { font-size: .75rem; color: #888; }
        .cert-seal { width: 80px; height: 80px; border-radius: 50%; border: 3px double #b8960c;
                     display: flex; align-items: center; justify-content: center;
                     margin: 0 auto 20px; color: #b8960c; font-size: 2rem; }
        .no-print { position: fixed; bottom: 2rem; right: 2rem; display: flex; gap: 10px; }
        .btn-print { background: #b8960c; color: white; border: none; padding: 12px 24px;
                     border-radius: 8px; cursor: pointer; font-size: 1rem; }
        .btn-back { background: white; color: #333; border: 1px solid #ddd; padding: 12px 24px;
                    border-radius: 8px; cursor: pointer; font-size: 1rem; text-decoration: none; }
        @@media print { .no-print { display: none; } body { background: white; } }
    </style>
</head>
<body>
    <div class="cert-wrap">
        <div class="cert-border"></div>
        <div class="cert-corner tl"></div>
        <div class="cert-corner tr"></div>
        <div class="cert-corner bl"></div>
        <div class="cert-corner br"></div>

        <div class="cert-seal"><i class="fa fa-graduation-cap" style="font-family:FontAwesome">🎓</i></div>
        <div class="cert-logo">KURSAL</div>
        <div class="cert-subtitle">Certifikatë e Përfundimit</div>
        <div class="cert-divider"></div>

        <div class="cert-title">Kjo certifikatë i jepet</div>
        <div class="cert-name">@Model.Student?.FullName</div>
        <div class="cert-body">
            për përfundimin me sukses të kursit
        </div>
        <div class="cert-course">@Model.Course?.Title</div>
        <div class="cert-body">
            nën udhëheqjen e instruktorit <strong>@Model.Course?.Instructor?.FullName</strong>
        </div>
        <div class="cert-date">
            Datë: @(Model.CompletedAt?.ToString("dd MMMM yyyy") ?? DateTime.Now.ToString("dd MMMM yyyy"))
        </div>

        <div class="cert-signatures">
            <div class="cert-sig">
                <div class="cert-sig-line"></div>
                <div class="cert-sig-name">@Model.Course?.Instructor?.FullName</div>
                <div class="cert-sig-role">Instruktor</div>
            </div>
            <div class="cert-sig">
                <div class="cert-sig-line"></div>
                <div class="cert-sig-name">KursAL</div>
                <div class="cert-sig-role">Platforma e Mësimit</div>
            </div>
        </div>
    </div>

    <div class="no-print">
        <a href="javascript:history.back()" class="btn-back">← Kthehu</a>
        <button onclick="window.print()" class="btn-print">🖨️ Printo / Shkarko</button>
    </div>
</body>
</html>
